{
  "manifest_version": 3,
  "name": "DeepSeek AI Workspace",
  "version": "1.0.0",
  "description": "Transform DeepSeek into a powerful AI workspace with projects, memory, and tools.",
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "scripts": [
      "src/background/index.js"
    ]
  },
  "action": {
    "default_title": "Open DeepSeek Workspace"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/index.js"
      ]
    }
  ],
  "icons": {
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "sidebar_action": {
    "default_panel": "src/sidebar/index.html",
    "default_title": "DeepSeek Workspace"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "workspace@deepseek.ai",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": [
          "technicalAndInteraction"
        ]
      }
    }
  }
}